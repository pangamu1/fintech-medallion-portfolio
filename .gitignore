# Datalake - Do not commit raw ingested data or logs
# Ignore everything under bronze/silver/gold/logs, then un-ignore .gitkeep so folder skeleton stays tracked
fintech_datalake/bronze/**
fintech_datalake/silver/**
fintech_datalake/gold/**
fintech_datalake/logs/**
!fintech_datalake/bronze/**/
!fintech_datalake/silver/**/
!fintech_datalake/gold/**/
!fintech_datalake/logs/**/
!fintech_datalake/bronze/**/.gitkeep
!fintech_datalake/silver/**/.gitkeep
!fintech_datalake/gold/**/.gitkeep
!fintech_datalake/logs/**/.gitkeep
